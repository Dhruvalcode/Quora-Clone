<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Main Page</title>
    <link rel="stylesheet" href="style.css">
  </head>
  <body>
    <h1>Quora Posts</h1>

   <% for (post of posts) { %>
        <div class="post">
            <h2 class="user"> @ <%= post.username %></h2>
            <h3 class="content"><%= post.content %></h3>
            <a href="/post/show/<%=post.id%>">See in detail</a> &nbsp; &nbsp;
              <a href="/post/edit/<%=post.id%>">Edit</a><br><br>
            
                <form action="/post/delete/<%=post.id%>?_method=DELETE" method="POST"><button>Delete</button></form>

               

        </div>
   <% } %>


   

   <a href="/post/new"> Create New Post </a>

  </body>
</html>
